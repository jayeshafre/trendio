  {"info": {
    "name": "Trendio API - Module 1 Auth",
    "description": "Complete Authentication API testing for Trendio E-Commerce Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1 - Register User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "// Auto-save tokens after registration",
              "if (jsonData.tokens) {",
              "    pm.collectionVariables.set('access_token', jsonData.tokens.access);",
              "    pm.collectionVariables.set('refresh_token', jsonData.tokens.refresh);",
              "    console.log('Tokens saved automatically!');",
              "}",
              "",
              "// Tests",
              "pm.test('Status is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response has tokens', function () {",
              "    pm.expect(jsonData.tokens).to.have.property('access');",
              "    pm.expect(jsonData.tokens).to.have.property('refresh');",
              "});",
              "",
              "pm.test('Response has user data', function () {",
              "    pm.expect(jsonData.user).to.have.property('email');",
              "    pm.expect(jsonData.user).to.have.property('username');",
              "});",
              "",
              "pm.test('Success message exists', function () {",
              "    pm.expect(jsonData.message).to.include('Welcome to Trendio');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"john@example.com\",\n    \"username\": \"johndoe\",\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"phone_number\": \"9876543210\",\n    \"password\": \"Test@1234\",\n    \"password2\": \"Test@1234\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/register/",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "register", ""]
        },
        "description": "Register a new user. Tokens are auto-saved to collection variables."
      }
    },
    {
      "name": "2 - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "// Auto-save tokens after login",
              "if (jsonData.tokens) {",
              "    pm.collectionVariables.set('access_token', jsonData.tokens.access);",
              "    pm.collectionVariables.set('refresh_token', jsonData.tokens.refresh);",
              "    console.log('Access Token saved: ' + jsonData.tokens.access);",
              "    console.log('Refresh Token saved: ' + jsonData.tokens.refresh);",
              "}",
              "",
              "// Tests",
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Access token received', function () {",
              "    pm.expect(jsonData.tokens.access).to.be.a('string');",
              "});",
              "",
              "pm.test('Refresh token received', function () {",
              "    pm.expect(jsonData.tokens.refresh).to.be.a('string');",
              "});",
              "",
              "pm.test('User data returned', function () {",
              "    pm.expect(jsonData.user.email).to.eql('john@example.com');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"Test@1234\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login/",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "login", ""]
        },
        "description": "Login with email and password. Tokens are auto-saved."
      }
    },
    {
      "name": "3 - View Profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Profile has email', function () {",
              "    pm.expect(jsonData).to.have.property('email');",
              "});",
              "",
              "pm.test('Profile has username', function () {",
              "    pm.expect(jsonData).to.have.property('username');",
              "});",
              "",
              "pm.test('Profile has date_joined', function () {",
              "    pm.expect(jsonData).to.have.property('date_joined');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/auth/profile/",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "profile", ""]
        },
        "description": "View logged-in user profile. Uses auto-saved access token."
      }
    },
    {
      "name": "4 - Update Profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Success message exists', function () {",
              "    pm.expect(jsonData.message).to.include('updated successfully');",
              "});",
              "",
              "pm.test('Updated name is correct', function () {",
              "    pm.expect(jsonData.user.first_name).to.eql('Johnny');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\": \"johndoe\",\n    \"first_name\": \"Johnny\",\n    \"last_name\": \"Doe\",\n    \"phone_number\": \"9999999999\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/profile/",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "profile", ""]
        },
        "description": "Update user profile details."
      }
    },
    {
      "name": "5 - Refresh Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "// Auto-save new access token",
              "if (jsonData.access) {",
              "    pm.collectionVariables.set('access_token', jsonData.access);",
              "    console.log('New access token saved!');",
              "}",
              "",
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('New access token received', function () {",
              "    pm.expect(jsonData).to.have.property('access');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"refresh\": \"{{refresh_token}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/token/refresh/",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "token", "refresh", ""]
        },
        "description": "Get a new access token using the refresh token."
      }
    },
    {
      "name": "6 - Change Password",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Success message exists', function () {",
              "    pm.expect(jsonData.message).to.include('Password changed successfully');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"old_password\": \"Test@1234\",\n    \"new_password\": \"NewTest@1234\",\n    \"new_password2\": \"NewTest@1234\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/change-password/",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "change-password", ""]
        },
        "description": "Change password for logged-in user."
      }
    },
    {
      "name": "7 - Logout",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "// Clear saved tokens after logout",
              "pm.collectionVariables.set('access_token', '');",
              "pm.collectionVariables.set('refresh_token', '');",
              "console.log('Tokens cleared after logout');",
              "",
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Logout message exists', function () {",
              "    pm.expect(jsonData.message).to.include('Logged out successfully');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"refresh\": \"{{refresh_token}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/logout/",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "logout", ""]
        },
        "description": "Logout and blacklist the refresh token. Tokens are cleared automatically."
      }
    },
    {
      "name": "ERROR TEST - Register Duplicate Email",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 400 Bad Request', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "pm.test('Error message returned', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('email');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"john@example.com\",\n    \"username\": \"johndoe2\",\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"password\": \"Test@1234\",\n    \"password2\": \"Test@1234\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/register/",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "register", ""]
        },
        "description": "Should return 400 - email already exists."
      }
    },
    {
      "name": "ERROR TEST - Login Wrong Password",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 401 Unauthorized', function () {",
              "    pm.response.to.have.status(401);",
              "});",
              "",
              "pm.test('Error message returned', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('error');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"WrongPassword123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login/",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "login", ""]
        },
        "description": "Should return 401 - invalid credentials."
      }
    },
    {
      "name": "ERROR TEST - Profile Without Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 401 Unauthorized', function () {",
              "    pm.response.to.have.status(401);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/auth/profile/",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "profile", ""]
        },
        "description": "Should return 401 - no token provided."
      }
    }
  ]
}